---

const { title, description, slug, ctaLabel, imageUrl, icon } = Astro.props;

---

          <article class="rounded-lg border-2 border-brand-purple p-4 w-full min-h-50">
            {imageUrl && (
              <img
                src={imageUrl}
                alt={title}
                class="h-48 w-full rounded object-cover"
              />
            )}
            <div class="mt-4 flex items-center gap-3">
              <i class={icon} aria-hidden="true" />
              <h2 class="text-xl font-semibold">{title}</h2>
            </div>
            <p class="mt-2 min-h-20">{description}</p>

            <a
              href={`/services/${slug}`}
              class="mt-4 inline-block rounded bg-brand-orange px-4 py-2 text-white"
            >
              {ctaLabel}
            </a>
          </article>