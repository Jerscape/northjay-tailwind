---
import { Image } from "astro:assets";
import logo from "../assets/northjay-logo.png";
---

<header>
  <div class="flex flex-col items-center md:flex-row md:items-center md:justify-between w-full md:w-3/4 mx-auto px-4 py-4 md:px-0">
    <div>
      <Image src={logo} alt="Northjay Solutions logo" class="w-70 h-auto" />
    </div>

    <nav aria-label="Primary Navigation">
      <ul class="flex flex-wrap gap-3">
        <li><a class="block px-3 py-2" href="/">Home</a></li>
        <li><a class="block px-3 py-2" href="/about">About</a></li>
        <li><a class="block px-3 py-2" href="/#services">Services</a></li>
        <li><a class="block px-3 py-2" href="/#contact">Contact</a></li>
  
      </ul>
    </nav>
  </div>
</header>
