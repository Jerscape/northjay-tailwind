    <div>
      <!-- <Image src={logo} alt="Northjay Solutions logo" class="w-70 h-auto" /> -->
<Image
  src={logoMobile}
  alt="Northjay Solutions logo"
  class="block sm:hidden w-56 h-auto"
/>

  <Image
    src={logo}
    alt="Northjay Solutions logo"
    class="hidden sm:block w-70 h-auto"
  />
      
    </div>

<nav aria-label="Primary Navigation">
  <ul class="flex flex-col items-center gap-1 mt-3 sm:mt-0 sm:flex-row sm:justify-center sm:gap-2">
    <li><a class="block px-3 py-1 text-lg font-medium" href="/">Home</a></li>
    <li><a class="block px-3 py-1 text-lg font-medium" href="/about">About</a></li>
    <li><a class="block px-3 py-1 text-lg font-medium" href="/#services">Services</a></li>
    <li><a class="block px-3 py-1 text-lg font-medium" href="/#contact">Contact</a></li>
