---
import { wixClient } from "../lib/wix.js";
import { media } from "@wix/sdk";
import ServiceCard from "./ServiceCard.astro";

const results = await wixClient.items
  .query("ServiceCards")
  .ascending("order")
  .find();

const serviceCards = results.items.map((card) => ({
  title: card.title_fld,
  description: card.description_fld,
  slug: card.slug,
  ctaLabel: card.ctaLabel,
  imageUrl: card.image_fld ? media.getImageUrl(card.image_fld).url : null,
  icon: card.icon,
}));
---

<section id="services" class="py-16 bg-slate-50">

  <div class="max-w-6xl mx-auto px-4 text-center mb-12">
    <h2 class="text-5xl font-bold text-slate-900 mb-4">
      It's a fact, your tech works better...when you don't do it alone.
    </h2>
  </div>

  <div class="max-w-6xl mx-auto px-4 mb-16 flex items-center gap-8">
    <div class="hidden lg:block shrink-0 text-slate-500 ">
      <!-- <i class="fa-regular fa-hand-back-point-right text-[160px]"></i> -->
      <!-- <i class="fa-solid fa-circle-caret-right text-[160px]"></i> -->
      <!-- <i class="fa-solid fa-comment-check text-[160px]"></i> -->
      <i class="fa-solid fa-computer text-[160px]"></i>

    </div>

    <ul class="space-y-4 flex-1">
      {/* Fact 1 */}

      <li
        class="fact-ghost"
      >
        <i class="fa-solid fa-comment-check text-[20px] text-blue-600 font-bold py-4"></i>
        <p class="text-slate-700 text-lg">
          <strong>It's impossible to know everything.</strong> Even if you have the
          know-how, it's hard to have the capacity to manage tech while focusing on
          your core business.
        </p>
      </li>

      {/* Fact 2 */}
     <li
        class="fact-ghost"
      >
        <i class="fa-solid fa-comment-check text-[20px] text-blue-600 font-bold py-4"></i>
        <p class="text-slate-700 text-lg">
          <strong>The "Out of the Box" Myth:</strong>  Software isn't ready-to-run on day one. It requires intentional setup,
            smart integrations, & ongoing coordination with your tech stack to stay
            aligned with your business goals.
        </p>
      </li>

      {/* Fact 3 */}
      <li
        class="fact-ghost"
      >
        <i class="fa-solid fa-comment-check text-[20px] text-blue-600 font-bold py-4"></i>
        <p class="text-slate-700 text-lg">
          <strong>ROI Matters.</strong> Very few businesses get proper ROI out of
          their tech spend. We help ensure that spend is meaningful and gets results.
        </p>
      </li>

      {/* Fact 4 */}
      <li
        class="fact-ghost"
      >
        <i class="fa-solid fa-comment-check text-[20px] text-blue-600 font-bold py-4"></i>
        <p class="text-slate-700 text-lg">
          <strong>Implementation is Key.</strong> Guidance isn't enough. You need
          someone to take care of the details and just "make it work."
        </p>
      </li>
    </ul>
  </div>

<div class="max-w-6xl mx-auto px-4 text-left mb-12">
  <p class="statement-block text-left">
    Small business dont always need full-time IT staff, but they do need help
    making the most of their tools. 
    With our fractional application management packages, you get affordable guidance, 
    seamless implementation, and ongoing support to build out your applications 
  </p>
</div>

<div class="max-w-6xl mx-auto px-4 text-left mb-12">
  <p class="statement-block">
    <strong>
      Let's talk about making <span class="underline">YOUR TECH</span> work better, together.
    </strong>
  </p>
  <div class="flex justify-center"><i class="fa-sharp-duotone fa-solid fa-chevrons-down text-[120px] transform scale-x-250 transform scale-y-75"></i></div>
</div>



  <div class="w-full md:w-3/4 mx-auto px-4">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        serviceCards.map((card) => (
          <ServiceCard
            title={card.title}
            description={card.description}
            slug={card.slug}
            ctaLabel={card.ctaLabel}
            imageUrl={card.imageUrl}
            icon={card.icon}
          />
        ))
      }
    </div>
  </div>
</section>
