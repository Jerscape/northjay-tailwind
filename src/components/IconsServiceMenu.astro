---
import { wixClient } from "../lib/wix.js";

const iconRowData = (await wixClient.items
  .query("ServiceCards")
  .find()).items;

---

<section class="flex flex-col md:py-15 gap-4 md:flex-row justify-between px-10 bg-brand-purple">
  {iconRowData.map((service) => (
    <div class="flex flex-col py-5 md:py-10 gap-5 flex items-center">
      <h3 class="text-2xl text-brand-off-white">{service.title_fld}</h3>
      <i class={`${service.icon} text-6xl text-brand-off-white`} aria-hidden="true"></i>
      {/* <img src={service.icon} alt={service.title} /> */}
    </div>
  ))}
</section>

