---
const {
  splitServicesHeading,
  serviceDescriptionLong,
  overviewPoint1,
  overviewPoint2,
  overviewPoint3,
  imageUrl,
  imageAltText,
} = Astro.props;

const bulletPoints = [
  overviewPoint1,
  overviewPoint2,
  overviewPoint3,
].filter(Boolean);
---

<section class="bg-white py-16">
  <div class="mx-auto max-w-screen-xl px-4 md:px-6">
    <div class="mx-auto grid w-full gap-10 lg:w-3/4 lg:grid-cols-2 lg:items-stretch">
      
      <div class="flex flex-col justify-center">
        <h2 class="text-3xl font-bold text-brand-purple md:text-4xl">
          {splitServicesHeading || "Service Overview"}
        </h2>

        <p class="mt-5 text-lg leading-relaxed text-gray-700">
          {serviceDescriptionLong || "Service description goes here."}
        </p>

        {bulletPoints.length > 0 && (
          <ul class="mt-8 space-y-4">
            {bulletPoints.map((point) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 shrink-0 text-brand-orange">
                  <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
                </span>
                <span class="text-base leading-relaxed text-gray-800">
                  {point}
                </span>
              </li>
            ))}
          </ul>
        )}
      </div>

      <div class="relative min-h-[320px] overflow-hidden rounded-xl">
        {imageUrl ? (
          <img
            src={imageUrl}
            alt={imageAltText || splitServicesHeading || "Service image"}
            class="absolute inset-0 h-full w-full object-cover"
          />
        ) : (
          <div class="flex h-full min-h-[320px] items-center justify-center bg-gray-100 text-gray-500">
            Image placeholder
          </div>
        )}
      </div>

    </div>
  </div>
</section>