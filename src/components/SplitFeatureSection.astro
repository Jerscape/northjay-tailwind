---
const {
  splitServicesHeading,
  serviceDescriptionLong,
  overviewPoint1,
  overviewPoint2,
  overviewPoint3,
  imageUrl,
  imageAltText,
  buttonCta
} = Astro.props;

const bulletPoints = [overviewPoint1, overviewPoint2, overviewPoint3].filter(Boolean);
---

<section>
  <div class=" flex flex-col justify-center align-items-center mx-auto w-3/4">
    <div class="flex flex-col md:flex-row">
      <div class="w-full md:w-1/2  py-5 flex flex-col justify-center gap-10 text-3xl">
        <h2 class="text-5xl font-bold">
          {splitServicesHeading || "Service Overview"}
        </h2>


        {bulletPoints.length > 0 && (
          <ul class="flex flex-col gap-3 px-10">
            {bulletPoints.map((point) => (
              <li class="flex items-start gap-4 text-3xl">
                <span class="mt-1 shrink-0 text-xl">
                  <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
                </span>
                <span class="text-2xl">
                  {point}
                </span>
              </li>
            ))}
          </ul>
        )}

        <button class="flex self-start p-2 border-2 border-brand-purple rounded-md !text-lg">Web That Works</button>
      </div>

      <div class="w-full md:w-1/2 py-5">
        {imageUrl ? (
          <img
            src={imageUrl}
            alt={imageAltText || splitServicesHeading || "Service image"}
            class="block h-[320px] w-full object-cover md:h-full"
          />
        ) : (
          <div class="flex h-[320px] w-full items-center justify-center bg-gray-200">
            Image placeholder
          </div>
        )}
      </div>
    </div>
  </div>
</section>