---
const {
  splitServicesHeading,
  serviceDescriptionLong,
  overviewPoint1,
  overviewPoint2,
  overviewPoint3,
  imageUrl,
  imageAltText,
  buttonCta
} = Astro.props;

const bulletPoints = [overviewPoint1, overviewPoint2, overviewPoint3].filter(Boolean);
---

<section class="py-12 md:py-16">
  <div class="mx-auto w-full md:w-3/4">
    <div class="flex flex-col md:flex-row">
      <div class="w-full md:w-1/2 px-6 py-8 md:px-10 md:py-10 lg:px-12 lg:py-12">
        <h2 class="text-3xl font-bold leading-tight md:text-4xl">
          {splitServicesHeading || "Service Overview"}
        </h2>


        {bulletPoints.length > 0 && (
          <ul class="mt-8 space-y-5">
            {bulletPoints.map((point) => (
              <li class="flex items-start gap-4">
                <span class="mt-1 shrink-0 text-xl">
                  <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
                </span>
                <span class="text-base leading-relaxed md:text-lg">
                  {point}
                </span>
              </li>
            ))}
          </ul>
        )}
      </div>

      <div class="w-full md:w-1/2">
        {imageUrl ? (
          <img
            src={imageUrl}
            alt={imageAltText || splitServicesHeading || "Service image"}
            class="block h-[320px] w-full object-cover md:h-full"
          />
        ) : (
          <div class="flex h-[320px] w-full items-center justify-center bg-gray-200">
            Image placeholder
          </div>
        )}
      </div>
    </div>
  </div>
</section>